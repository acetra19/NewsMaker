# NewsMaker Bot – copy to .env and fill in

# Reddit (PRAW) – https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=NewsMakerBot/1.0
SUBREDDITS=singularity,ArtificialIntelligence,futurology,technews
MIN_UPVOTES=1000

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ElevenLabs (optional; leave empty to use edge-tts)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
USE_EDGE_TTS_FALLBACK=true

# Pexels – https://www.pexels.com/api/
PEXELS_API_KEY=

# Replicate (optional, for AI images)
REPLICATE_API_TOKEN=

# YouTube – path to OAuth client secrets JSON
YOUTUBE_CLIENT_SECRETS_JSON=./client_secrets.json
